{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/VisuCom/InfographyFundamental.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/VisuCom/InfographyFundamental.vue","mtime":1779100722490},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["InfographyFundamental.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsDA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"InfographyFundamental.vue","sourceRoot":"src/views/VisuCom","sourcesContent":["<template>\n  <div>\n    <Header />\n    <Menu />\n    <h3 id=\"InfographyFundamental\">\n      LES FONDAMENTAUX DE L'INFOGRAPHIE\n    </h3>\n    <p>\n      L’infographie est un format de communication très utilisé sur le Web et\n      dans la presse, réalisé à l’aide d’un outil informatique. L'infographie propose au\n      lecteur une information illustrée en recourant à des graphiques, des\n      chiffres, des images et du texte. Son objectif est de restituer sous un\n      format visuel et synthétique un contenu ciblé. Percutante et attrayante,\n      l’infographie privilégie une organisation rigoureuse des données afin de\n      permettre au lecteur d’appréhender rapidement l’information rassemblée.\n      Pourquoi l’infographie est-elle si efficace{{'\\xa0'}}? Comment créer sa propre\n      infographie{{'\\xa0'}}? Quels sont les outils en ligne pour la concevoir{{'\\xa0'}}?\n    </p>\n    <h4>\n      Comprendre l'infographie grâce à l'infographie\n    </h4>\n    <p>\n      Créer une infographie, c'est proposer une organisation visuelle de\n      l'information avec un message, une rédaction et une visualisation.\n    </p>\n    <Galery v-bind:galery-picture=\"galeryInfographyFundamental\"></Galery>\n\n    <h4 class=\"breath\">\n      Réaliser une infographie : comment et avec quels outils ?\n    </h4>\n    <b-row align-h=\"center\">\n      <iframe\n        src=\"//www.slideshare.net/slideshow/embed_code/key/clMtUzqEiuZp3S\"\n        width=\"595\"\n        height=\"485\"\n        frameborder=\"0\"\n        marginwidth=\"0\"\n        marginheight=\"0\"\n        scrolling=\"no\"\n        style=\"border:1px solid #CCC; border-width:1px; margin-bottom:5px; max-width: 100%;\"\n        allowfullscreen\n      >\n      </iframe>\n    </b-row>\n    <p class=\"text-vid\">De Virginie Colombel</p>\n    <NextPrevBtn\n      v-bind:nxtprev-list=\"nxtprevInfographyFundamental\"\n     />\n    <Footer />\n  </div>\n</template>\n<style lang=\"scss\"></style>\n\n<script lang=\"ts\">\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Galery from \"@/components/Galery.vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Galery,\n    Header,\n    Menu,\n    NextPrevBtn,\n    Footer,\n  },\n})\nexport default class InfographyFundamental extends Vue {\n  protected galeryInfographyFundamental: string[] = [\n    \"picture_Infography/fundamental_infography.png\",\n    \"picture_Infography/fundamental_infography2.jpg\",\n  ];\n  protected nxtprevInfographyFundamental = {\n    BoolPrev: false,\n    BoolNext: true,\n    PrevImage: \"\",\n    NextImage: \"/thumbnail6.png\",\n    PrevLink: \"\",\n    NextLink: \"/Infographie/Astuces\",\n  };\n}\n</script>\n"]}]}