{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefStrategy.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefStrategy.vue","mtime":1778495073275},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["DefStrategy.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAqOA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"DefStrategy.vue","sourceRoot":"src/views/OWcom","sourcesContent":["<template>\n  <div>\n    <Header />\n    <Menu />\n    <h3>\n      STRATÉGIES DE COMMUNICATION\n    </h3>\n    <p>\n      Que vous soyez chargé.e de communication dans un cadre professionnel,\n      institutionnel ou encore associatif, que vous vous occupiez de\n      communication interne ou externe, vous trouverez ici les méthodes\n      indispensables pour mettre en œuvre une stratégie et des outils de\n      communication efficaces : pourquoi communiquer ? Comment définir une cible\n      ? Quel est l'objectif à atteindre ? Quel plan de communication envisager ?\n      Quels outils et canaux de communication privilégier ?... Étape par étape,\n      appliquez cette méthodologie du questionnement à votre propre projet.\n    </p>\n    <h4>\n      Créer des outils de communication\n    </h4>\n    <p>\n      Pas à pas, découvrez comment créer votre communication en vous posant les\n      bonnes questions. Ces recommandations de l'Unicef valent pour tous les\n      projets de communication.\n    </p>\n    <a\n      class=\"subtitle-link pdf-line\"\n      href=\"/pdf_OWcom/ComTool.pdf\"\n      download=\"fiche_initiative_creer_outils_communication.pdf\"\n    >\n      Créer des outils de communication et des partenariats pour valoriser mon\n      action <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://www.unicef.fr/sites/default/files/fiche_initiative_creer_outils_communication.pdf\"\n        target=\"_blank\"\n      >\n        <i> source : </i>www.unicef.fr <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <h4>\n      Les basiques de la communication\n    </h4>\n    <p>\n      Qu'est-ce qu'un plan de communication{{'\\xa0'}}? À quoi servent les supports web{{'\\xa0'}}?\n      Quel support imprimé privilégier{{'\\xa0'}}? Comment développer ses relations presse{{'\\xa0'}}? \n      Ce petit guide à l'usage des associations apporte les outils\n      fondamentaux à toute organisation qui souhaite communiquer efficacement.\n    </p>\n    <a\n      class=\"subtitle-link pdf-line\"\n      href=\"/pdf_OWcom/COM.pdf\"\n      download=\"Guide de la communication.pdf\"\n    >\n      Guide de la communication\n      <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://www.guidepratiqueasso.org/images/2017-2018/4_COM_2018.pdf\"\n        target=\"_blank\"\n      >\n        <i> source : </i>www.guidepratiqueasso.org\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <h4>\n      Établir le plan de communication d’un projet\n    </h4>\n    <p>\n      Vous êtes impliqué.e dans un projet ? Que vous soyez sponsor, chef de projet\n      professionnel ou occasionnel, gestionnaire d’un portefeuille de projets ou\n      tout simplement membre d’une équipe de projet, les documents ci-dessous\n      vous proposent une méthode complète pour élaborer le plan de communication\n      de votre projet.\n    </p>\n    <Pdf v-bind:galery-pdf=\"pdfDefStrat\"></Pdf>\n    <p><i> Sources : </i></p>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"http://cdt64.media.tourinsoft.eu/upload/Le-Plan-de-communication.pdf\"\n        target=\"_blank\"\n      >\n        cdt64.media.tourinsoft.eu\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"http://cpcoop.fr/wp-content/uploads/2015/01/Fiches_PlanDeCom.pdf\"\n        target=\"_blank\"\n      >\n        <i class=\"easter-egg\">dat Luna</i>cpcoop.fr\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://fedweb.belgium.be/sites/default/files/downloads/COMM12_FR_web_interactive.pdf\"\n        target=\"_blank\"\n      >\n        <i class=\"easter-egg\">Who win</i>fedweb.belgium.be\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <h4>\n      La sélection des moyens de communication\n    </h4>\n    <p>\n      Le plan média est la liste des supports sélectionnés et des dates retenues\n      pour la diffusion des messages publicitaires. Il a pour objectif d’obtenir\n      la meilleure couverture possible de la cible qui a été définie dans la\n      stratégie de communication. Comment définir sa stratégie et son plan média\n      ?\n    </p>\n    <a\n      class=\"subtitle-link pdf-line\"\n      href=\"/pdf_OWcom/PlanMedia.pdf\"\n      download=\"Etablir le plan de communication d’un projet.pdf\"\n    >\n      Le plan média <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://www.est-usmba.ac.ma/Alaoui/cours%20internet/plan_m%C3%83%C2%A9dia.pdf\"\n        target=\"_blank\"\n      >\n        <i> Source : </i>www.est-usmba.ac.ma\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <h4>\n      Guide pratique des principaux outils de communication\n    </h4>\n    <p>\n      Communiqué de presse, outils de promotion, publicité, plan de\n      communication...{{'\\xa0'}}: guide des bonnes pratiques de la communication.\n    </p>\n    <a\n      class=\"subtitle-link pdf-line\"\n      href=\"/pdf_OWcom/MainComTool.pdf\"\n      download=\"Guide Principaux outils de communication.pdf\"\n    >\n      Principaux outils de communication\n      <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://cdchauteyamaska.ca/wp-content/uploads/2012/10/Guide-pratique-principaux-outils-de-communication.pdf\"\n        target=\"_blank\"\n      >\n        <i> Source : </i>cdchauteyamaska.ca\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <h4>\n      La communication interne\n    </h4>\n    <p>\n      Comprendre les fondements et les éléments théoriques de la communication\n      interne, aborder la communication interne digitale, le journal\n      d'entreprise, l'événementiel, apprendre à faire face à une communication\n      interne de crise... Tels sont les objectifs de ce cours de Pauline Folcher\n      de l'Université de Montpellier.\n    </p>\n    <a\n      class=\"subtitle-link pdf-line\"\n      href=\"/pdf_OWcom/InterneCom.pdf\"\n      download=\"Communication interne.pdf\"\n    >\n      Communication interne\n      <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://moodle.umontpellier.fr › pluginfile.php › course › overviewfiles\"\n        target=\"_blank\"\n      >\n        <i> Source : </i>moodle.umontpellier.fr\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <h4>\n      Les différents réseaux sociaux et leurs spécificités\n    </h4>\n    <p>\n      La présence d’une association sur les réseaux sociaux ne relève presque\n      pas d’un choix, mais plutôt d’une nécessité. En revanche, pour que cette\n      décision soit productive et diffuse le meilleur de vous-même, il s’agit\n      d’être pertinent quant à la qualité de votre présence digitale. En effet,\n      tous les médias sociaux ne se valent pas.\n    </p>\n    <a\n      class=\"subtitle-link pdf-line\"\n      href=\"/pdf_OWcom/NetCom.pdf\"\n      download=\"Communication et Reseau Sociaux.pdf\"\n    >\n      Communication et Reseau Sociaux\n      <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n    <div>\n      <a\n        class=\"subtitle-link\"\n        href=\"https://www.forim.net/sites/default/files/support%20info.pdf\"\n        target=\"_blank\"\n      >\n        <i> Source : </i>www.forim.net\n        <b-icon icon=\"box-arrow-right\" />\n      </a>\n    </div>\n    <NextPrevBtn v-bind:nxtprev-list=\"nxtprevDefStrategy\" />\n    <Footer />\n  </div>\n</template>\n\n<style></style>\n\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport { BIcon, BIconBoxArrowRight } from \"bootstrap-vue\";\nimport Pdf from \"@/components/Pdf.vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Header,\n    Menu,\n    BIcon,\n    BIconBoxArrowRight,\n    Pdf,\n    NextPrevBtn,\n    Footer,\n  },\n})\nexport default class DefStrategy extends Vue {\n  protected pdfDefStrat = [\n    {\n      PdfLink: \"/pdf_OWcom/PlanCom.pdf\",\n      PdfDownload:\n        \"Pourquoi et comment concevoir son plan de communication\\xa0?\",\n      TxtPdf: \"Plan de communication\",\n    },\n    {\n      PdfLink: \"/pdf_OWcom/PlanCom2.pdf\",\n      PdfDownload: \"Le plan de communication\",\n      TxtPdf: \"Le plan de communication\",\n    },\n    {\n      PdfLink: \"/pdf_OWcom/PlanCom3.pdf\",\n      PdfDownload: \"Etablir le plan de communication d’un projet\",\n      TxtPdf: \"Etablir le plan de communication d’un projet\",\n    },\n  ];\n  protected nxtprevDefStrategy = {\n    BoolPrev: true,\n    BoolNext: false,\n    PrevImage: \"/thumbnail3.png\",\n    NextImage: \"\",\n    PrevLink: \"/Definition_Communication/Situation_Communication\",\n    NextLink: \"\",\n  };\n}\n</script>\n"]}]}