{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefShare.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefShare.vue","mtime":1781788802446},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["DefShare.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkDA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"DefShare.vue","sourceRoot":"src/views/OWcom","sourcesContent":["<template>\n  <div>\n    <Header />\n    <Menu />\n    <h3>\n      COMMUNIQUER, C'EST ÉCHANGER\n    </h3>\n    <p><u>La communication</u></p>\n    <div class=\"margin\">\n      <ul>\n        <li class=\"first-list\">\n          L’étymologie du terme nous renseigne sur le sens à donner à la\n          communication{{ \"\\xa0\" }}: en latin, <i>communicare</i> signifie «{{\n            \"\\xa0\"\n          }}avoir part, partager{{ \"\\xa0\" }}». Composé de <i>cum/munus</i> ou\n          <i>cum/municus</i>, il signifie «{{ \"\\xa0\" }}être en relation avec{{\n            \"\\xa0\"\n          }}» (<i>cum</i>{{ \"\\xa0\" }}: avec, <i>munus</i>{{ \"\\xa0\" }}: charge,\n          fonction).\n        </li>\n        <li class=\"first-list\">\n          Au XVIe siècle, la communication désigne littéralement la mise en\n          commun, l’échange mais également une manière d’être ensemble, un mode\n          privilégié de relations sociales.\n        </li>\n      </ul>\n    </div>\n    <br>\n    <ShareTheory></ShareTheory>\n    <ShareFeedBack></ShareFeedBack>\n    <ShareSchematic></ShareSchematic>\n    <h3 id=\"NoneResponse\">\n      LE \"MONDE\" DE LA NON-RÉPONSE\n    </h3>\n    <p>\n      Dans un monde où les échanges se sont démultipliés (téléphone, e-mails,\n      messageries instantanées...), la communication est devenue massive.\n      Difficile de répondre à toutes les sollicitations dans une ère de constant\n      zapping... S'étend alors le \"monde\" de la non-réponse qui peut être lourde\n      en répercussions.\n    </p>\n    <img class=\"horizontal\" draggable=\"false\"  src=\"/picture_OWcom/schematic/No-Answer.jpg\" alt=\"Le monde de la non-réponse\">\n    <NextPrevBtn v-bind:nxtprev-list=\"nxtprevDefShare\" />\n    <Footer />\n  </div>\n</template>\n\n<style></style>\n\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport ShareTheory from \"@/views/OWcom/DefShare/ShareTheory.vue\";\nimport ShareFeedBack from \"@/views/OWcom/DefShare/ShareFeedBack.vue\";\nimport ShareSchematic from \"@/views/OWcom/DefShare/ShareSchematic.vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Header,\n    Menu,\n    ShareTheory,\n    ShareFeedBack,\n    ShareSchematic,\n    NextPrevBtn,\n    Footer,\n  },\n})\nexport default class DefShare extends Vue {\n  protected nxtprevDefShare = {\n    BoolPrev: false,\n    BoolNext: true,\n    PrevImage: \"\",\n    NextImage: \"/thumbnail7.png\",\n    PrevLink: \"\",\n    NextLink: \"/Definition_Communication/Types_Communication\",\n  };\n}\n</script>\n"]}]}