xt-align: justify;\n  margin-left: 5.5%;\n  margin-bottom: 0.5rem;\n}\n\n.logo-network {\n  height: 3vh;\n  margin: 1vh 1vw 2vh 1vw;\n  text-align: center;\n}\n@media (min-width: 600px){\n  .divide-footer {\n  border-right: solid 1px #1d4f8f;\n}\n}\n\n.link-footer {\n  color: white !important;\n}\n.link-footer-legal {\n  color: #bce8ff !important;\n}\n.link-footer-writer {\n  color: #2694cd !important;\n}\n#WebMaster {\n  margin-left: 4vw;\n}\n</style>\n\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport {\n  BIcon,\n  BIconEnvelope,\n  BIconGeoAlt,\n  BIconList,\n  BIconDiamond,\n} from \"bootstrap-vue\";\n\n@Component({\n  components: {\n    BIcon,\n    BIconEnvelope,\n    BIconGeoAlt,\n    BIconList,\n    BIconDiamond,\n  },\n})\nexport default class Footer extends Vue {\n  // export default==protected class\n}\n</script>\n"]}]}