{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Appfile/CVVideo.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Appfile/CVVideo.vue","mtime":1782055437510},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["CVVideo.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA4DA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"CVVideo.vue","sourceRoot":"src/views/Appfile","sourcesContent":["<template>\n  <div id=\"CVVideo\">\n    <Header />\n    <Menu />\n    <h3 id=\"videoCV\">\n      LE CV VIDÉO\n    </h3>\n    <p class=\" none-margin-bottom\">\n      Le CV vidéo vous donne une occasion de vous démarquer, de mettre davantage\n      de chances de votre côté. Il montre également que vous maîtrisez les\n      nouveaux outils de communication, que vous vous exprimez avec aisance à\n      l'oral et éventuellement en plusieurs langues.\n    </p>\n\n    <strong>\n      <a\n        href=\"https://www.cadremploi.fr/editorial/conseils/conseils-candidature/cv/detail/article/les-10-commandements-du-cv-video.html\"\n        target=\"_blank\"\n        class=\"subtitle-link\"\n        >Conseils pour un bon CV vidéo <b-icon icon=\"box-arrow-right\"></b-icon\n      ></a>\n    </strong>\n\n    <h4>\n      Evitez certaines erreurs dans les CV vidéos\n    </h4>\n\n    <b-row align-h=\"center\">\n      <iframe\n        width=\"560\"\n        height=\"315\"\n        src=\"https://www.youtube.com/embed/wW-ar7qtQC8 \"\n        frameborder=\"0\"\n        allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\"\n        allowfullscreen\n      ></iframe>\n    </b-row>\n    <p class=\"text-vid\">Chaîne{{ \"\\xa0\" }}: Fyte4U</p>\n    <h4>\n      Exemples de CV vidéo\n    </h4>\n    <p>\n      Marketing, traduction, design... Tous ces CV vidéo regorgent d’idées et\n      vous prouvent qu’il est toujours possible de trouver des moyens originaux\n      de s’exprimer par l’audiovisuel, quels que soient votre domaine d’études\n      et vos compétences.\n    </p>\n    <Video v-bind:galery-video=\"videoCVVideo\" v-bind:id-video=\"'cv2'\"></Video>\n    <NextPrevBtn v-bind:nxtprev-list=\"nxtprevCVVideo\" />\n    <Footer />\n  </div>\n</template>\n<style lang=\"scss\">\n#CVVideo {\n  scroll-behavior: smooth;\n  overflow: auto;\n  height: 100vh;\n}\n</style>\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Video from \"@/components/Video.vue\";\nimport { BIcon, BIconBoxArrowRight } from \"bootstrap-vue\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Video,\n    BIcon,\n    BIconBoxArrowRight,\n    Header,\n    Menu,\n    NextPrevBtn,\n    Footer\n  }\n})\nexport default class CVVideo extends Vue {\n  protected videoCVVideo = [\n    {\n      videoSrc: \"https://www.youtube.com/embed/Ohiv5xhJB9g\",\n      videoTitle: \"CV vidéo Lilian Guinebretière BUT GEII\",\n      videoRoot: \"Chaîne :  Peggy Raffy-Hideux Communication\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/Fz6bZaPzPuw\",\n      videoTitle: \"Le film d'animation - Dai Duong Tran\",\n      videoRoot: \"Chaîne :  Dai Duong Tran\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/SHY3Etcag4w\",\n      videoTitle: \"Génialement simple - Cristina Castro\",\n      videoRoot: \"Chaîne :   Cristina Castro\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/0OyPyRkwszs\",\n      videoTitle: \"Agréable à lire - Patrice Co\",\n      videoRoot: \"Chaîne : Patrice Co\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/OPMZoS1CcAI\",\n      videoTitle: \"cerveau disponible Edouard PRIET\",\n      videoRoot: \"Chaîne :  edouard priet\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/1SkeJ5fzk6Q\",\n      videoTitle: \"CV Jean-Benoist Werth\",\n      videoRoot: \"Chaîne :   Jean-Benoist Werth\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/ZusmOZ65NPs\",\n      videoTitle: \"CV vidéo Sophie Garrigues\",\n      videoRoot: \"Chaîne : sophie\"\n    },\n    {\n      videoSrc: \"https://www.dailymotion.com/embed/video/x72m5n\",\n      videoTitle: \"Charlotte Ruault CV\",\n      videoRoot: \"Chaîne :  krakotte_53\"\n    }\n  ];\n  protected nxtprevCVVideo = {\n    BoolPrev: true,\n    BoolNext: true,\n    PrevImage: \"/thumbnail3.png\",\n    NextImage: \"/thumbnail5.png\",\n    PrevLink: \"/CV/Outils\",\n    NextLink: \"/CV/Aller_Plus_Loin\"\n  };\n}\n</script>\n"]}]}