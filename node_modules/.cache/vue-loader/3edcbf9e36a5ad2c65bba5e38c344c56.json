{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Art/ArtPerfStudents.vue?vue&type=style&index=0&lang=scss&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Art/ArtPerfStudents.vue","mtime":1782060970742},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/css-loader/dist/cjs.js","mtime":1782069226200},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":1782069227959},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/postcss-loader/src/index.js","mtime":1782069226704},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/sass-loader/dist/cjs.js","mtime":1782069225727},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCiNQZXJmIHsKICBzY3JvbGwtYmVoYXZpb3I6IHNtb290aDsKICBvdmVyZmxvdzogYXV0bzsKICBoZWlnaHQ6IDEwMHZoOwp9Cg=="},{"version":3,"sources":["ArtPerfStudents.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAuGA;AACA;AACA;AACA;AACA","file":"ArtPerfStudents.vue","sourceRoot":"src/views/Art","sourcesContent":["<template>\n  <div id=\"Perf\">\n    <Header />\n    <Menu />\n    <h3>PERFORMANCES D'ÉTUDIANTS IUT GEII</h3>\n    <p>\n      Le département Génie électrique et informatique industrielle (GEII) de\n      l’IUT d’Angers organise, depuis 2017, son concours de performances\n      artistiques qui implique près de cent étudiants de première année du BUT\n      GEII, le « Perf’Art GEII ». Par leur engagement sur scène, les étudiants\n      défendent leur point de vue sur des thèmes riches et variés qui leur\n      tiennent à cœur{{ \"\\xa0\" }}: surconsommation, sens de la vie, addiction\n      aux réseaux sociaux, souffrance animale ou encore harcèlement scolaire…\n      Une grande fête de la créativité, une ouverture sur le monde mais aussi et\n      surtout un beau moment de partage.\n    </p>\n    <h4>\n      Le Perf’Art GEII en images\n    </h4>\n    <b-row align-h=\"center\">\n      <iframe\n        width=\"560\"\n        height=\"315\"\n        src=\"https://www.youtube.com/embed/fNd2hcmQtik\"\n        frameborder=\"0\"\n        allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\"\n        allowfullscreen\n      >\n      </iframe>\n    </b-row>\n    <p class=\"text-vid\">Chaîne : Perf'Art GEII Angers</p>\n\n    <h4>La note d’intention{{ \"\\xa0\" }}: un outil pour créer sa performance</h4>\n    <a\n      class=\"subtitle-link  pdf-line\"\n      href=\"/pdf_Perf/IntentPerf.pdf\"\n      download=\"NoteIntentionPerfArt\"\n    >\n      La note d’intention{{ \"\\xa0\" }} Perf’Art\n      <img class=\"logo-pdf\" src=\"../../assets/logo-pdf.png\" />\n    </a>\n    <h4>\n      Exemples de performances\n    </h4>\n    <p>\n      <strong> «{{ \"\\xa0\" }}Entr'Haine{{ \"\\xa0\" }}»</strong>. L’entraide ou\n      l’entre-soi ? Ou comment dénoncer la solitude lors du confinement ?\n      Performance réalisée par des étudiants en IUT GEII (Nathan, Mathis, Robin\n      et Alexis) chez eux lors du second confinement. Inutile de régler le\n      volume sonore, la vidéo est silencieuse, par choix artistique.\n    </p>\n    <b-row align-h=\"center\">\n      <iframe\n        width=\"560\"\n        height=\"315\"\n        src=\"https://www.youtube.com/embed/iYRXDn2PZw4\"\n        frameborder=\"0\"\n        allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\"\n        allowfullscreen\n      ></iframe>\n    </b-row>\n    <p class=\"text-vid\">Contenu soumis à des droits d'auteurs</p>\n    <p>\n      <strong> «{{ \"\\xa0\" }}W@tched{{ \"\\xa0\" }}»</strong>. Souriez... Vous êtes\n      filmés. Ou comment dénoncer la surveillance de masse ? Performance\n      réalisée par des étudiants en IUT GEII (Arthur, Léo et Mathias) dans la\n      ville d'Angers.\n    </p>\n    <b-row align-h=\"center\">\n      <iframe\n        width=\"560\"\n        height=\"315\"\n        src=\"https://www.youtube.com/embed/57CjCvvaCdg\"\n        frameborder=\"0\"\n        allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\"\n        allowfullscreen\n      ></iframe>\n    </b-row>\n    <p class=\"text-vid\">Contenu soumis à des droits d'auteurs</p>\n    <p>\n      <strong> «{{ \"\\xa0\" }}Bleu Cellulaire{{ \"\\xa0\" }}»</strong>. Quand les\n      écrans nous font voir la vie en bleu (Damien, Séverin, Alexis et Simon).\n    </p>\n    <b-row align-h=\"center\">\n      <iframe\n        width=\"560\"\n        height=\"315\"\n        src=\"https://youtube.com/embed/9DHitmdWqWg\"\n        frameborder=\"0\"\n        allow=\"accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture\"\n        allowfullscreen\n      ></iframe>\n    </b-row>\n    <p class=\"text-vid\">Contenu soumis à des droits d'auteurs</p>\n    <h4>\n      Autres exemples de performances…\n    </h4>\n    <Video v-bind:galery-video=\"videoPerf\" v-bind:id-video=\"'perf'\"></Video>\n    <NextPrevBtn v-bind:nxtprev-list=\"nxtprevArtPerfStudents\" />\n    <Footer />\n  </div>\n</template>\n<style lang=\"scss\">\n#Perf {\n  scroll-behavior: smooth;\n  overflow: auto;\n  height: 100vh;\n}\n</style>\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport Video from \"@/components/Video.vue\";\nimport { BIcon, BIconUpload } from \"bootstrap-vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Header,\n    Menu,\n    Video,\n    BIcon,\n    BIconUpload,\n    NextPrevBtn,\n    Footer\n  }\n})\nexport default class ArtPerfStudents extends Vue {\n  protected videoPerf = [\n    {\n      videoSrc: \"https://www.youtube.com/embed/fizlZKMboSE\",\n      videoTitle: \"Océans Bienséants\",\n      videoRoot: \"Contenu soumis à des droits d'auteur\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/uxf2s2HgSqw\",\n      videoTitle: \"Jetez-moi\",\n      videoRoot: \"Contenu soumis à des droits d'auteur\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/juhGAAl08zw\",\n      videoTitle: \"Évolution technologique et corps\",\n      videoRoot: \"Contenu soumis à des droits d'auteur\"\n    },\n    {\n      videoSrc: \"https://www.youtube.com/embed/jKJ6cm-zUdM\",\n      videoTitle: \"Du champ des possibles\",\n      videoRoot: \"Contenu soumis à des droits d'auteur\"\n    },\n    {\n      videoSrc: \"https://youtube.com/embed/yD9pcWDJt84\",\n      videoTitle: \"Cacophonie Écologique\",\n      videoRoot: \"Contenu soumis à des droits d'auteur\"\n    },\n    {\n      videoSrc: \"https://youtube.com/embed/5cJ6BVc-ZHw\",\n      videoTitle: \"Votez Futile\",\n      videoRoot: \"Contenu soumis à des droits d'auteur\"\n    }\n  ];\n  protected nxtprevArtPerfStudents = {\n    BoolPrev: true,\n    BoolNext: true,\n    PrevImage: \"/thumbnail7.png\",\n    NextImage: \"/thumbnail2.png\",\n    PrevLink: \"/PerformanceArtistique/Origines\",\n    NextLink: \"/PerformanceArtistique/CorpusdeTexte\"\n  };\n}\n</script>\n"]}]}