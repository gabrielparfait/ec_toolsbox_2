{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Art/ReadClassic.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Art/ReadClassic.vue","mtime":1773604670451},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["ReadClassic.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgOA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"ReadClassic.vue","sourceRoot":"src/views/Art","sourcesContent":["<template>\n  <div>\n    <Header />\n    <Menu />\n    <h3>LES CLASSIQUES</h3>\n\n    <b-container fluid class=\"margin\">\n      <b-row class=\"justify-content-md-start reading reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Vie.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}La vie devant soi{{'\\xa0'}}», Romain Gary\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Madame Rosa est une ancienne prostituée qui a connu Auschwitz.\n            Aujourd’hui, elle gère une pension pour les enfants dont les mères\n            ne peuvent pas s'occuper, comme Momo, un môme d’une dizaine d’années\n            qui aime Madame Rosa plus que tout. C’est d’ailleurs lui le\n            narrateur cru et touchant de «{{'\\xa0'}}La vie devant soi{{'\\xa0'}}», une œuvre\n            bouleversante et déstabilisante.\n          </p>\n        </b-col>\n      </b-row>\n      <b-row class=\"justify-content-md-center reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Portrait.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Le Portrait de Dorian Gray{{'\\xa0'}}», Oscar Wilde\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Dorian Gray a fait le vœu de ne jamais vieillir et celui-ci se\n            réalise miraculeusement chaque jour. Le jeune dandy profite de la\n            chance qui lui est donnée pour jouir de tous les plaisirs de la vie,\n            alors que seul son portrait semble porter les stigmates du temps qui\n            passe. «{{'\\xa0'}}Les folies sont les seules choses qu’on ne regrette jamais\n           {{'\\xa0'}}», écrit Oscar Wilde dans ce qui restera son seul roman, hymne à\n            l’hédonisme.\n          </p>\n        </b-col>\n      </b-row>\n      <b-row class=\"justify-content-md-end reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Orwell.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}1984{{'\\xa0'}}», George Orwell\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Roman essentiel de science-fiction, «{{'\\xa0'}}1984{{'\\xa0'}}» touche à la\n            surveillance façon «{{'\\xa0'}}Big Brother{{'\\xa0'}}», mais aussi à la délation, à la\n            propagande et à l’étouffement de tout sens critique. En bref, tout\n            ce qui est, encore aujourd'hui, utilisé pour la mise en place d’une\n            pensée unique. Moderne et troublant.\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-center reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Goriot.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Le Père Goriot{{'\\xa0'}}», Balzac\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            La maison Vauquer est une pension parisienne où se côtoient des\n            résidents que tout oppose, et pourtant inexorablement liés. Tous ont\n            leurs secrets et leurs faiblesses{{'\\xa0'}}: Rastignac, obsédé par la haute\n            société, délaisse ses études pour tenter de s’y intégrer{{'\\xa0'}}; Vautrin\n            cache un passé douloureux{{'\\xa0'}}; le Père Goriot s’est ruiné pour ses\n            filles ingrates.\n          </p>\n          <p class=\"text-read\">\n            La maison Vauquer s’apparente alors à une peinture de cette époque,\n            un cliché de personnages aussi différents qu’unis, criants de\n            vérité, acteurs d’une comédie humaine.\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-start reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Route.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Sur la route{{'\\xa0'}}», Jack Kerouac\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Le roman raconte les aventures de l'auteur et d'un compagnon de\n            route, Dean Moriarty. On y croise plusieurs personnages fascinants.\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-center reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Echec.jpeg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Le Joueur d’échecs{{'\\xa0'}}», Stefan Zweig\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Qui est cet inconnu capable d'en remontrer au grand Czentovic, le\n            champion mondial des échecs, véritable prodige aussi fruste\n            qu'antipathique{{'\\xa0'}}? Peut-on croire, comme il l'affirme, qu'il n'a pas\n            joué depuis plus de vingt ans{{'\\xa0'}}? Voilà un mystère que les passagers\n            oisifs de ce paquebot de luxe essaient de percer…\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-end reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Seigneur.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Belle du Seigneur{{'\\xa0'}}», Albert Cohen\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Dans les années 1930, Solal, bel homme juif, haut fonctionnaire de\n            la Société des Nations, tombe amoureux d’Ariane, une jeune femme\n            prisonnière d’un mariage médiocre. Après des débuts pas terribles,\n            ils connaissent l’amour fou avant que les complications n’arrivent…\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-center reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Ecume.jpeg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}L’écume des jours{{'\\xa0'}}», Boris Vian\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Deux histoires d’amour s’entremêlent{{'\\xa0'}}: Colin est un jeune homme\n            élégant, rentier, qui met fin à son célibat en épousant Chloé,\n            rencontrée à une fête, tandis que son ami Chick, fanatique transi du\n            philosophe vedette Jean-Sol Partre, entretient une relation avec\n            Alise. Tout irait pour le mieux sans les forces conjuguées de la\n            maladie (Chloé est victime d’un «{{'\\xa0'}}nénuphar{{'\\xa0'}}» qui lui dévore le\n            poumon) et du consumérisme (Chick consume ses ressources dans sa\n            passion pour Jean-Paul Sartre) qui s’acharnent sur les quatre amis.\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-start reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Magnifique.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Gatsby le magnifique{{'\\xa0'}}», Francis Scott Fitzgerald\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Au début des années 1920, dans une débauche de luxe, d'alcool et\n            d'argent, un mystérieux personnage s'installe à Long Island dans un\n            domaine incroyable d'extravagance. Qui est ce charmant et légendaire\n            Gatsby, incarnation du pouvoir et de la réussite, dont les fêtes\n            attirent toute la société locale{{'\\xa0'}}? Les rumeurs les plus folles\n            circulent. Un espion{{'\\xa0'}}? Un gentleman anglais{{'\\xa0'}}? Un héros de guerre? Un\n            mythomane{{'\\xa0'}}? Une vérité plus profonde se cache derrière l'orgueil et\n            la magnificence de Gatsby, celle d'un ancien adolescent pauvre et\n            d'un amant trahi qui ressemble beaucoup à Fitzgerald lui-même.\n          </p>\n        </b-col>\n      </b-row>\n\n      <b-row class=\"justify-content-md-center reading\">\n        <b-col sm=\"auto\"\n          ><img src=\"/picture_read/Classic/Mrs.jpg\" class=\"picture-book\" />\n        </b-col>\n        <b-col sm=\"6\">\n          <p class=\"text-read\">\n            <strong>\n              «{{'\\xa0'}}Mrs Dalloway{{'\\xa0'}}», Virginia Woolf\n            </strong>\n          </p>\n          <p class=\"text-read\">\n            Le roman, publié en 1925, raconte la journée d'une femme élégante de\n            Londres, en mêlant impressions présentes et souvenirs, personnages\n            surgis du passé, comme un ancien amour, ou membres de sa famille et\n            de son entourage. Ce grand monologue intérieur exprime la difficulté\n            de relier soi et les autres, le présent et le passé, le langage et\n            le silence, le mouvement et l'immobilité.\n          </p>\n        </b-col>\n      </b-row>\n    </b-container>\n    <NextPrevBtn v-bind:nxtprev-list=\"nxtprevReadClassic\" />\n    <Footer />\n  </div>\n</template>\n<style lang=\"scss\"></style>\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport { BIcon, BIconUpload } from \"bootstrap-vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Header,\n    Menu,\n    BIcon,\n    BIconUpload,\n    NextPrevBtn,\n    Footer,\n  },\n})\nexport default class ReadClassic extends Vue {\n  protected nxtprevReadClassic =\n  {\n    BoolPrev: true,\n    BoolNext: true,\n    PrevImage: \"/thumbnail4.png\",\n    NextImage: \"/thumbnail2.png\",\n    PrevLink: \"/PlaisirdeLire/RenouerAvecLaLecture\",\n    NextLink: \"/PlaisirdeLire/LesEssaisEtTemoignages\",\n  };\n}\n</script>\n"]}]}