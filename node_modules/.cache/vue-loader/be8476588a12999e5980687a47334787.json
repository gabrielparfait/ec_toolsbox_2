différentes natures…\n      </p>\n    </div>\n    <HomeArticle></HomeArticle>\n    <Footer />\n  </div>\n</template>\n\n<style lang=\"scss\">\n#WelcomePage {\n  position: relative;\n  scroll-behavior: smooth;\n  overflow: auto;\n  height: 100vh;\n}\n#full-seen{\n  line-height: 1.5rem !important;\n}\n@font-face {\n  font-family: Myriad;\n  src: url(../../assets/MyriadProBC.otf);\n}\n@font-face {\n  font-family: MyriadPhone;\n  src: url(../../assets/MyriadProB.ttf);\n}\n.none-margin-bottom {\n  margin-bottom: 0;\n}\n#TextIntro {\n  animation-name: appear2ndWelcome;\n  animation-duration: 3s;\n}\n.none-margin-top {\n  margin-top: 0;\n}\n#about {\n  padding-top: 2vh;\n  margin-bottom: 0;\n}\n\nh5 {\n  color: #c21b2c;\n  font-family: Myriad, Arial;\n  padding-top: 2vh;\n}\n\n.pdf-line {\n  border-bottom: solid 1px #85def9;\n}\n.logo-pdf {\n  height: 1.5rem;\n}\n.margin-reduced{\n  width: 50vw;\n  margin : 0% 10%;\n  margin-bottom : -6%\n}\n$marginText:1% 10%;\n$marginTitle:0% 10%;\n@media (min-width: 600px) {\n  p {\n    text-align: justify;\n    color: #2e367f;\n    margin: $marginText;\n    line-height: 1.7rem;\n  }\n  .subtitle-link {\n    text-decoration: none !important;\n    color: #2e367f;\n    margin-left: 10%;\n  }\n  h2 {\n    color: #2694cd;\n\n    font-family: Myriad, Arial;\n    margin: $marginTitle;\n    padding: 8vh 0 4vh 0;\n  }\n  h3 {\n    color: #1794d6;\n    font-family: Myriad, Arial;\n    margin: $marginTitle;\n\n    padding: 8vh 0 2vh 0;\n  }\n\n  h4 {\n    color: #c21b2c;\n    font-family: Myriad, Arial;\n    margin: $marginTitle;\n    padding: 4vh 0 0 0;\n  }\n  .subtitle-h5 {\n    margin: 2% 10% 0 10%;\n    color: #2e367f;\n    font-family: Myriad;\n    padding: 1vh 0 1vh 0;\n  }\n  .subtitle-h5-list {\n    margin: 0% 10% -1% 10%;\n    color: #2e367f;\n    font-family: Myriad;\n  }\n  h6 {\n    padding: 5% 0;\n    margin: $marginTitle;\n    color: #2e367f;\n    font-family: Myriad;\n    text-align: left;\n  }\n  h7 {\n    margin: 1% 10% 0;\n    color: #1794d6;\n    font-family: Myriad;\n    font-size: 1.2em;\n  }\n  .margin {\n    color: #2e367f;\n  }\n  .supperposition {\n    width: 10vw;\n    height: 20vh;\n    opacity: 0.1;\n    position: relative;\n    top: -20vh;\n    right: 0px;\n    z-index: 11;\n    display: inline-block;\n    &:hover {\n      opacity: 0.3;\n    }\n  }\n  .Help_Builder {\n    width: 10vw;\n    position: relative;\n    height: 20vh;\n    border: solid 1px #85def9;\n    z-index: 10;\n  }\n  .link-help-builder {\n    width: 10vw;\n    height: 20vh;\n    display: inline-block;\n    margin: 1%;\n  }\n  .vertical {\n    width: 40vw;\n    margin:  $marginText;\n  }\n  .square {\n    height: 80vh;\n    width: auto !important;\n    margin:  $marginText;\n    margin-left: auto !important;\n    margin-right: auto !important;\n    display: block;\n  }\n  .horizontal {\n    width: 50vw;\n    margin: 4% 10%;\n  }\n}\n$MarginPhone: 1% 3%;\n@media (max-width: 600px) {\n  p {\n    text-align: justify;\n    color: #2e367f;\n    margin: $MarginPhone;\n  }\n  .subtitle-link {\n    text-decoration: none !important;\n    color: #2e367f;\n    display: inline-block;\n    margin: $MarginPhone;\n  }\n  h2 {\n    color: #2694cd;\n    font-family: Myriad, Arial;\n    margin:  $MarginPhone;\n    padding: 8vh 0 4vh 0;\n  }\n  h3 {\n    color: #1794d6;\n    font-family: Myriad, Arial;\n    margin:  $MarginPhone;\n    padding: 8vh 0 2vh 0;\n  }\n\n  h4 {\n    color: #c21b2c;\n    font-family: Myriad, Arial;\n    margin: $MarginPhone;\n    padding: 4vh 0 0 0;\n  }\n  .subtitle-h5 {\n    margin: $MarginPhone;\n    color: #2e367f;\n    font-family: Myriad;\n    padding: 1vh 0 1vh 0;\n  }\n  h6 {\n    padding: 5% 0;\n    margin: $MarginPhone;\n    color: #2e367f;\n    font-family: Myriad;\n    text-align: left;\n  }\n  h7 {\n    margin: $MarginPhone;\n    color: #1794d6;\n    font-family: Myriad;\n    font-size: 1.2em;\n  }\n  .margin {\n    margin: $MarginPhone;\n    color: #2e367f;\n  }\n  .supperposition {\n    display: none;\n  }\n  .Help_Builder {\n    width: 7rem;\n    height: 7rem;\n    border: solid 1px #85def9;\n    z-index: 10;\n  }\n  .link-help-builder {\n    width: 7rem;\n    height: 7rem;\n    display: block;\n    margin: $MarginPhone;\n  }\n  .vertical {\n    width: 75vw;\n    margin: 1% 10%;\n  }\n  .square {\n    width: 80vw;\n\n    margin: $MarginPhone;\n    display: block;\n  }\n  .horizontal {\n    width: 75vw;\n    margin: 4% 10%;\n  }\n}\n\n@keyframes appear2ndWelcome {\n  0% {\n    opacity: 0;\n  }\n  50% {\n    opacity: 0;\n  }\n  75% {\n    opacity: 0.5;\n  }\n  100% {\n    opacity: 1;\n  }\n}\na {\n  outline: none;\n}\ntable {\n  margin-left: auto; //auto need width to work\n  margin-right: auto;\n}\ntd {\n  padding: 1% 0;\n  text-align: center;\n}\n.color-fire {\n  height: 15vh;\n}\n.text-vid {\n  color: #c21b2c;\n  text-align: center;\n}\n\n.list-link {\n  text-decoration: none !important;\n  color: #2e367f;\n}\n.insert-video {\n  margin-bottom: 0;\n}\n.perf-vid {\n  width: 75vw;\n}\n.first-list {\n  margin-top: 1vh;\n}\n.Logo {\n  margin: 0 5%;\n  width: 8vw;\n}\n.icon {\n  margin: 10%;\n}\n.row {\n  margin-right: 0 !important;\n}\n.breath {\n  margin-bottom: 3%;\n}\n\n.breath-top {\n  margin-top: 3%;\n}\n\n.a-bloc {\n  display: block;\n}\n.easter-egg {\n  color:white; \n  cursor: default;\n}\n</style>\n<script>\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport HomeBanner from \"@/views/Home/HomeBanner.vue\";\nimport HomeArticle from \"@/views/Home/HomeArticle.vue\";\nimport Footer from \"@/components/Footer.vue\";\n\n@Component({\n  components: {\n    Header,\n    Menu,\n    HomeBanner,\n    HomeArticle,\n    Footer,\n  },\n})\nexport default class Home extends Vue {}\n</script>\n"]}]}