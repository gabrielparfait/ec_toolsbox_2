{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Appfile/CVExample.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Appfile/CVExample.vue","mtime":1782055390852},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["CVExample.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;AA0BA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"CVExample.vue","sourceRoot":"src/views/Appfile","sourcesContent":["<template>\n  <div>\n    <Header />\n    <Menu />\n    <h3 id=\"exampleCV\">\n      EXEMPLES DE CV (IUT)\n    </h3>\n    <p>\n      Chaque année, en France, des millions d'étudiants postulent à un stage ou\n      à un premier emploi. À expérience et diplômes équivalents, ils peuvent\n      faire la différence en personnalisant leur CV. Le plus important est de\n      trouver un compromis entre votre personnalité et la rigueur que le monde\n      professionnel attend par rapport au domaine d'expertise. Ces exemples de\n      CV réalisés par des étudiants d'IUT vous apporteront des pistes pour\n      élaborer un CV personnalisé et attractif.\n    </p>\n    <Galery\n      v-bind:galery-picture=\"cvIut\"\n      v-bind:classheight=\"'square'\"\n    ></Galery>\n    <NextPrevBtn v-bind:nxtprev-list=\"nxtprevCVExample\" />\n    <Footer />\n  </div>\n</template>\n\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\n\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport Galery from \"@/components/Galery.vue\";\nimport NextPrevBtn from \"@/components/NextPrevBtn.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Galery,\n    Header,\n    Menu,\n    NextPrevBtn,\n    Footer\n  }\n})\nexport default class CVExample extends Vue {\n  protected cvIut: string[] = [\n    \"/picture_cv/Example_CV_IUT1.jpg\",\n    \"/picture_cv/Example_CV_IUT2.jpg\",\n    \"/picture_cv/Example_CV_IUT3.jpg\",\n    \"/picture_cv/Example_CV_IUT4.jpg\",\n    \"/picture_cv/Example_CV_IUT5.jpg\",\n    \"/picture_cv/Example_CV_IUT6.jpg\"\n  ];\n  protected nxtprevCVExample = {\n    BoolPrev: true,\n    BoolNext: true,\n    PrevImage: \"/thumbnail1.png\",\n    NextImage: \"/thumbnail3.png\",\n    NextLink: \"/CV/CV_Video\",\n    PrevLink: \"/CV/Outils\"\n  };\n}\n</script>\n"]}]}