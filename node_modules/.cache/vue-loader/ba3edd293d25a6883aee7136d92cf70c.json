{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefContex/ContexSocial.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefContex/ContexSocial.vue","mtime":1782057365190},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCmltcG9ydCB7IENvbXBvbmVudCwgVnVlIH0gZnJvbSAidnVlLXByb3BlcnR5LWRlY29yYXRvciI7CgpAQ29tcG9uZW50KHsKICBjb21wb25lbnRzOiB7fQp9KQpleHBvcnQgZGVmYXVsdCBjbGFzcyBDb250ZXhTb2NpYWwgZXh0ZW5kcyBWdWUge30K"},{"version":3,"sources":["ContexSocial.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+EA;;AAEA;AACA;AACA;AACA","file":"ContexSocial.vue","sourceRoot":"src/views/OWcom/DefContex","sourcesContent":["<template>\n  <div>\n    <h4>\n      LA FONCTION SOCIALE DE LA COMMUNICATION\n    </h4>\n    <p>\n      Le langage, comme l’allure physique, se dotent d’une fonction sociale dans\n      la communication. Ils apportent une indication sur{{ \"\\xa0\" }}:\n    </p>\n    <div class=\"margin-list\">\n      <ul>\n        <li>\n          notre personnalité,\n        </li>\n        <li>\n          notre milieu,\n        </li>\n        <li>\n          notre capacité d’adaptation aux normes linguistiques.\n        </li>\n      </ul>\n      Différence entre «{{ \"\\xa0\" }}J’ai eu ce job à l’arrache{{ \"\\xa0\" }}» et\n      «{{ \"\\xa0\" }}j’ai obtenu ce poste de justesse{{ \"\\xa0\" }}».\n    </div>\n    <p>\n      L’apparence physique est un élément de communication. C’est à partir de\n      ses traits visibles qu’une personne est analysée{{ \"\\xa0\" }}:\n    </p>\n    <div class=\"margin-list\">\n      <ul>\n        <li>\n          tenue,\n        </li>\n        <li>\n          posture,\n        </li>\n        <li>\n          gestuelle.\n        </li>\n      </ul>\n    </div>\n    <p id=\"FirstImp\">\n      La part des informations qui passent par des perceptions visuelles est\n      estimée à 55 %{{ \"\\xa0\" }}!\n    </p>\n    <img\n      class=\"square\"\n      draggable=\"false\"\n      src=\"/picture_OWcom/schematic/schema_Impression.jpg\"\n      alt=\"information_impression\"\n    />\n    <p>\n      En conclusion{{ \"\\xa0\" }}: pour exercer l’art de la communication, il est\n      primordial d’œuvrer par étape{{ \"\\xa0\" }}:\n    </p>\n    <div class=\"margin\">\n      <ul>\n        <li>L'écoute,</li>\n        <li>La réflexion,</li>\n        <li>L'écriture,</li>\n        <li>L'exposé oral,</li>\n        <li>L'action</li>\n      </ul>\n    </div>\n    <br />\n    <img\n      class=\"vertical\"\n      draggable=\"false\"\n      src=\"/picture_OWcom/schematic/table_seror.jpg\"\n      alt=\"Tableau_Seror\"\n    />\n\n    <p>D’après Georges Séror, <i>Communication</i>, Dunod, 2016</p>\n  </div>\n</template>\n\n<style lang=\"scss\"></style>\n\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\n\n@Component({\n  components: {}\n})\nexport default class ContexSocial extends Vue {}\n</script>\n"]}]}