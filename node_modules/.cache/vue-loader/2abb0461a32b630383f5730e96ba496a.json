{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefContex/ContexConstruction.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/OWcom/DefContex/ContexConstruction.vue","mtime":1781789383352},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["ContexConstruction.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkFA;;AAEA;AACA;AACA;AACA","file":"ContexConstruction.vue","sourceRoot":"src/views/OWcom/DefContex","sourcesContent":["<template>\n  <div>\n    <h4>LA CO-CONSTRUCTION DU SENS...</h4>\n    <p>La communication{{ \"\\xa0\" }}: un processus d’adaptation permanent</p>\n    <p>Les individus produisent{{ \"\\xa0\" }}:</p>\n    <div class=\"margin-list\">\n      <ul>\n        <li>du sens{{ \"\\xa0\" }};</li>\n        <li>co-construisent du sens{{ \"\\xa0\" }};</li>\n        <li>\n          partagent des significations.\n        </li>\n      </ul>\n    </div>\n    <p>\n      Et doivent mettre en place des réajustements permanents, à partir{{\n        \"\\xa0\"\n      }}:\n    </p>\n    <div class=\"margin-list\">\n      <ul>\n        <li>de reformulations{{ \"\\xa0\" }};</li>\n        <li>de questionnements{{ \"\\xa0\" }};</li>\n        <li>\n          d'objections.\n        </li>\n      </ul>\n    </div>\n    <p>\n      L’acte de parole{{ \"\\xa0\" }}: «{{ \"\\xa0\" }}N’arrive pas trop tard, s’il te\n      plaît{{ \"\\xa0\" }}!{{ \"\\xa0\" }}» suppose une conception commune du mot «{{\n        \"\\xa0\"\n      }}tard{{ \"\\xa0\" }}».\n    </p>\n    <div id=\"quote\">\n      <p class=\"quote\">Entre</p>\n      <p class=\"quote\">Ce que je pense,</p>\n      <p class=\"quote\">Ce que je veux dire,</p>\n      <p class=\"quote\">Ce que je crois dire,</p>\n      <p class=\"quote\">Ce que je dis,</p>\n      <p class=\"quote\">Ce que vous avez envie d'entendre,</p>\n      <p class=\"quote\">Ce que vous entendez,</p>\n      <p class=\"quote\">Ce que vous comprenez...</p>\n      <p class=\"quote2\">\n        il y a dix possibilités qu'on ait des difficultés à communiquer.\n      </p>\n      <p class=\"quote2\">Mais essayons quand même...</p>\n    </div>\n    <p class=\"quote3\">Bernard Werber</p>\n    <p class=\"quote3\">\n      Extrait de <i>l’Encyclopédie du savoir relatif et absolu, 1993</i>\n    </p>\n    <h4 id=\"Glasses\">...ET LES PROCESSUS INTERPRÉTATIFS</h4>\n    <img\n      class=\"square\"\n      draggable=\"false\"\n      src=\"/picture_OWcom/schematic/schema_com.png\"\n      alt=\"Schema_Werber\"\n    />\n  </div>\n</template>\n\n<style lang=\"scss\">\n.quote {\n  color: #c94a19;\n  margin: 0 10%;\n}\n.quote2 {\n  color: #772f12;\n  margin: 0 10%;\n}\n.quote3 {\n  color: #772f12;\n  margin: 1% 10%;\n}\n.margin-list {\n    color: #2e367f;\n    margin : 0 10%\n  }\n</style>\n\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\n\n@Component({\n  components: {},\n})\nexport default class ContexConstruction extends Vue {}\n</script>\n"]}]}