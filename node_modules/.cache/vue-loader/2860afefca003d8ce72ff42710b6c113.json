{"remainingRequest":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js??vue-loader-options!/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Intro/WhoAmI.vue?vue&type=script&lang=ts&","dependencies":[{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/src/views/Intro/WhoAmI.vue","mtime":1782060194112},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/babel-loader/lib/index.js","mtime":1782069226669},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/ts-loader/index.js","mtime":1782069227079},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/cache-loader/dist/cjs.js","mtime":1782069225765},{"path":"/home/gabou/Bureau/ec_toolsbox_new-main/node_modules/vue-loader/lib/index.js","mtime":1782069227058}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["WhoAmI.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"WhoAmI.vue","sourceRoot":"src/views/Intro","sourcesContent":["<template>\n  <div>\n    <Header />\n    <Menu />\n    <div id=\"container-intro\">\n      <h2>À PROPOS - PEGGY RAFFY-HIDEUX</h2>\n\n      <img\n        id=\"background-logo\"\n        src=\"../../assets/basic-Graph/Logo3.png\"\n        atl=\"Peggy Raffy-Hideux Logo Design\"\n      />\n      <p class=\"margin\">\n        Diplômée d'un DESS (Master 2) en Ingénierie éditoriale-communication et\n        docteure en Littérature française, générale et comparée, je suis\n        enseignante certifiée en Lettres. J'enseigne actuellement la Culture et\n        la Communication, principalement à l'IUT d'Angers dans le Département\n        GEII (Génie Electrique et Informatique Industrielle) et suis, par\n        ailleurs, conceptrice des sujets de concours d'entrée en école de\n        commerce ACCÈS (synthèse, ouverture culturelle, agilité culturelle) et\n        membre de l'AECIUT (Association des Enseignants en Communication des\n        IUT). Après avoir publié deux essais littéraires sur les romans\n        réunionnais et haïtiens, j'articule aujourd'hui mes domaines de\n        recherche autour de la Communication et de la pédagogie dans le\n        Supérieur. Dernières publications en date : \"Les Premiers entretiens de\n        recrutement. Les clés pour se démarquer et réussir. Concours, stages,\n        emplois\" (Ellipses, 2020) et \"Culture générale : 80 images pour\n        développer votre agilité culturelle - Concours et examens\" (DUNOD, 2025,\n        réédition 2027).\n      </p>\n      <br />\n    </div>\n    <Publish></Publish>\n    <Footer />\n  </div>\n</template>\n<style lang=\"scss\">\n@media (min-width: 600px) {\n  #background-logo {\n    position: absolute;\n    z-index: -1;\n    opacity: 0.1;\n    height: 120%;\n    margin-left: 5%;\n    top: 2rem;\n  }\n  .margin {\n    margin-bottom: -2%;\n  }\n}\n@media (max-width: 600px) {\n  #background-logo {\n    position: absolute;\n    z-index: -1;\n    opacity: 0.1;\n    width: 90%;\n    margin-left: 5%;\n    top: 6rem;\n  }\n}\n#container-intro {\n  position: relative;\n}\n</style>\n<script lang=\"ts\">\nimport { Component, Vue } from \"vue-property-decorator\";\nimport Header from \"@/components/Header.vue\";\nimport Menu from \"@/components/Menu.vue\";\nimport Publish from \"@/views/Intro/Publish.vue\";\nimport Footer from \"@/components/Footer.vue\";\n@Component({\n  components: {\n    Header,\n    Menu,\n    Publish,\n    Footer\n  }\n})\nexport default class WhoAmI extends Vue {}\n</script>\n"]}]}